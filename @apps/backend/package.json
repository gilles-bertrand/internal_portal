{
  "name": "@apps/backend",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "types": "src/api-types.ts",
  "main": "app.bootstrap.js",
  "scripts": {
    "dev": "pnpm build:deps && concurrently \"pnpm turbo build:watch --filter ^...\" \"vite-node --watch src/app.bootstrap.ts\"",
    "start": "pnpm build:deps && vite-node src/app.bootstrap.ts",
    "start:e2e": "pnpm build:deps && vite-node --mode=e2e src/app.bootstrap.ts",
    "e2e:setup": "vite-node --mode=e2e node_modules/@mikro-orm/cli/cli.js schema:fresh --seed E2ESeeder --run",
    "test": "pnpm vitest run",
    "build": "pnpm vite build",
    "build:watch": "concurrently \"pnpm vite build --watch\"",
    "build:deps": "pnpm turbo build --filter ^...",
    "lint": "pnpm concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:js": "oxlint",
    "api:types": "vite-node src/gen-openapi.ts && openapi-typescript ./openapi.json --output ./src/api-types.ts",
    "lint:format": "oxfmt check src tests",
    "lint:format:fix": "oxfmt fix src tests",
    "format": "pnpm lint:format:fix",
    "mikro-orm": "vite-node node_modules/@mikro-orm/cli/cli.js",
    "lint:fix": "oxlint --fix",
    "schema:update": "pnpm mikro-orm schema:update --run",
    "schema:drop": "pnpm mikro-orm schema:drop --run",
    "seed": "pnpm mikro-orm seeder:run",
    "schema:fresh": "vite-node src/cli/schema-fresh.ts"
  },
  "dependencies": {
    "@fastify/cookie": "catalog:",
    "@fastify/cors": "catalog:",
    "@fastify/passport": "catalog:",
    "@fastify/session": "catalog:",
    "@fastify/swagger": "catalog:",
    "@fastify/swagger-ui": "catalog:",
    "@libs/access-registry-backend": "workspace:*",
    "@libs/audit-log-backend": "workspace:*",
    "@libs/backend-shared": "workspace:*",
    "@libs/todos-backend": "workspace:*",
    "@libs/users-backend": "workspace:*",
    "@mikro-orm/core": "7.1.4",
    "@mikro-orm/seeder": "catalog:",
    "@types/nodemailer": "catalog:",
    "date-fns": "catalog:",
    "fastify": "5.8.5",
    "fastify-type-provider-zod": "catalog:",
    "fastify-zod": "catalog:",
    "handlebars": "catalog:",
    "jsonwebtoken": "catalog:",
    "mailgen": "catalog:",
    "nodemailer": "catalog:",
    "passport-local": "catalog:",
    "pino": "catalog:",
    "pino-pretty": "catalog:",
    "playwright": "^1.60.0",
    "true-myth": "catalog:",
    "ts-dotenv": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@fastify/flash": "catalog:",
    "@fastify/secure-session": "catalog:",
    "@fastify/static": "catalog:",
    "@fastify/vite": "~9.0.2",
    "@libs/repo-utils": "workspace:*",
    "@mikro-orm/cli": "catalog:",
    "@mikro-orm/postgresql": "7.1.4",
    "@ngneat/falso": "catalog:",
    "@swc/core": "catalog:",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/jsonwebtoken": "catalog:",
    "@types/node": "^25.9.3",
    "@types/passport-http-bearer": "catalog:",
    "@types/passport-jwt": "catalog:",
    "@types/passport-local": "catalog:",
    "@types/pdf-parse": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "better-sqlite3": "^12.10.0",
    "concurrently": "~10.0.3",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "passport-http-bearer": "catalog:",
    "passport-jwt": "catalog:",
    "pdf-parse": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "type-fest": "catalog:",
    "vite": "catalog:",
    "vite-node": "~6.0.0",
    "vite-plugin-node": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/mikro-orm.config.ts",
      "./dist/mikro-orm.config.js"
    ]
  },
  "volta": {
    "extends": "../../package.json"
  }
}
